# Environment variables template for Sentinel RFP Agent
# ---------------------------------------------------
# Core application
NODE_ENV=development

# Ollama (RAG side‑car)
OLLAMA_HOST=http://localhost:11434

# ChromaDB (vector store)
CHROMA_DB_URL=http://localhost:8000

# Optional external APIs (uncomment and set if needed)
# GOOGLE_GENERATIVE_API_KEY=
