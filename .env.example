# ==============================================================================
# Sentinel RFP Agent - Enterprise Environment Variables Template
# ==============================================================================
# Copy this file to '.env' and customize it for your deployment environment.
# All sensitive variables are defaulted to secure development values here.
# For production systems, you MUST replace placeholder values with cryptographically
# strong credentials.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Core Service Configuration
# ------------------------------------------------------------------------------
# Set to 'production' to enforce strict gRPC Token Authentication, TLS/Secure Local TCP
# bindings, rate limiting controls, and secure directory checking.
# Options: 'development', 'production'
ENV=production

# ------------------------------------------------------------------------------
# 2. Security & Token Authentication
# ------------------------------------------------------------------------------
# Cryptographically strong API Key used to authenticate gRPC requests across sidecars.
# Every communication between the Tauri frontend and python/rust sidecars will present
# this key via the 'x-sentinel-token' metadata header.
API_KEY=sentinel-secret-api-key-production-change-me

# ChromaDB dynamic Token Authentication. Used to secure Chroma vector database.
CHROMA_AUTH_TOKEN=sentinel-chroma-bearer-token-production-change-me

# ------------------------------------------------------------------------------
# 3. Database & Datastore URLs
# ------------------------------------------------------------------------------
# SQLite primary database URL configuration
DATABASE_URL=sqlite:sentinel.db

# Redis connection URL. Enforces dynamic password authentication ('requirepass') and local
# loopback binding to completely eliminate unauthorized WAN/LAN discovery.
REDIS_URL=redis://:sentinel-redis-secure-pass@redis:6379

# ChromaDB endpoint url (used by RAG sidecar)
CHROMA_URL=http://chromadb:8000

# ------------------------------------------------------------------------------
# 4. Large Language Model (Ollama)
# ------------------------------------------------------------------------------
# Port map for the local Ollama daemon
OLLAMA_PORT=11434

# Endpoint URL for Ollama service inside the network bridge
OLLAMA_URL=http://ollama:11434

# ------------------------------------------------------------------------------
# 5. Distributed Tracing & Observability
# ------------------------------------------------------------------------------
# OTLP collector gRPC endpoint for telemetry (e.g. Jaeger or OpenTelemetry Collector)
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317

# ------------------------------------------------------------------------------
# 6. Third-party Intelligence Integration (Optional)
# ------------------------------------------------------------------------------
# Google Gemini API key used by scraping agents for complex RFP parsing and extraction.
# Leave commented or empty to default to standard local parsing stubs.
# GOOGLE_GENERATIVE_API_KEY=your_gemini_api_key_here
